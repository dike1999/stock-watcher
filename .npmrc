# ~/.npmrc 或 项目根目录/.npmrc

# 主镜像源
registry=https://mirrors.cloud.tencent.com/npm/

# Electron 镜像（使用淘宝，更可靠）
electron_mirror=https://npmmirror.com/mirrors/electron/
electron_builder_binaries_mirror=https://npmmirror.com/mirrors/electron-builder-binaries/

# 二进制包镜像
sass_binary_site=https://mirrors.cloud.tencent.com/node-sass/
phantomjs_cdnurl=https://mirrors.cloud.tencent.com/phantomjs/
chromedriver_cdnurl=https://mirrors.cloud.tencent.com/chromedriver/

# 网络优化
fetch-retries=5
fetch-retry-factor=2
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=30000
strict-ssl=false
progress=true

# 其他配置
save-exact=true
package-lock=true
fund=false
audit=false